---
// src/components/Footer.astro
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Footer.astro';
---

{/* Render the original/actual Starlight footer so your site still looks normal */}
<Default {...Astro.props} />

<script is:inline src="https://www.biblegateway.com/public/link-to-us/tooltips/bglinks.js"></script>
<script is:inline>
  function applyBibleLinks() {
    // Check if the library has loaded yet
    if (window.BGLinks) {
      BGLinks.version = "NASB1995";
      BGLinks.linkVerses();
    }
  }

  // Run immediately on the first page load
  applyBibleLinks();

  // Run every time Starlight navigates to a new page
  document.addEventListener('astro:page-load', applyBibleLinks);
</script>